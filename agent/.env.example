# ─── Cobo Agentic Wallet（caw onboard 后从 ~/.cobo-agentic-wallet 凭证取）───
AGENT_WALLET_API_URL=https://api.agenticwallet.cobo.com
AGENT_WALLET_API_KEY=
AGENT_WALLET_WALLET_UUID=

# ─── agentSigner（合约只认这个地址签的名，必须等于链上 agentSigner()）───
AGENT_PRIVATE_KEY=

# ─── 合约（Sepolia，以合约负责人最新部署日志为准）───
POOL_ADDRESS=0x876A0741223EDdaE081Ef22beA513E92335B1Bd5
USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
PROJECT_ID=1
ROUND_ID=1
CHAIN_ID=11155111
COBO_CHAIN_ID=SETH
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ─── CAW 当 executor 发交易（caw CLI + 预建 pact）───
# CAW_PACT_ID：覆盖 ContributionPool 合约的 active pact（caw pact submit 后取）
# CAW_SRC_ADDRESS：CAW 钱包 EVM 地址（caw wallet current）
# CAW_BIN：可选，默认 ~/.cobo-agentic-wallet/bin/caw
CAW_PACT_ID=
CAW_SRC_ADDRESS=
