# CGHub × Cobo Agentic Wallet 示例
# 复制此文件为 .env 并填入真实值

# CAW API 端点（固定）
AGENT_WALLET_API_URL=https://api.agenticwallet.cobo.com

# Agent API Key（来自 Cobo Agentic Wallet 控制台 或 caw onboard）
AGENT_WALLET_API_KEY=your-agent-api-key-here

# Wallet UUID（创建钱包后可在控制台获取）
AGENT_WALLET_WALLET_ID=your-wallet-uuid-here

# 可选：默认转帐目标地址
CAW_DESTINATION=0x1111111111111111111111111111111111111111
